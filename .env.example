# Copy to `.env` and fill in your values.
GEMINI_API_KEY="your_api_key_here"

# Default Gemini model for meal photo analysis (latency-optimized; override anytime in UI).
OXIA_GEMINI_VISION_MODEL=gemini-2.0-flash

# JWT secret used by the FastAPI auth layer.
# Keep this stable: changing it invalidates all existing browser tokens (users must log in again).
# Use at least 32 random characters in production.
OXIA_JWT_SECRET="change-me-in-production"

# Session lifetime in minutes (default 7 days for local dev).
OXIA_JWT_TTL_MINUTES=10080

# Optional: where the SQLite DB is stored.
OXIA_DB_PATH="oxia.sqlite3"

# Optional: local Ollama endpoint (used for image + chat).
# On Windows, if you see "model not found" while `ollama list` works, try 127.0.0.1 instead of localhost.
OLLAMA_BASE_URL="http://127.0.0.1:11434"

# Default vision model for the dashboard (equivalent to `ollama run llava` / `ollama pull llava:latest`).
# UI will stream-pull this when you select it. Examples: llava:latest, llava, llama3.2-vision
OXIA_OLLAMA_VISION_MODEL=llava:latest

# Optional: HuggingFace token (used for chat-only).
HF_TOKEN=""

# Optional: USDA FoodData Central API key (better quota than DEMO_KEY for ingredient fallbacks).
# Sign up: https://fdc.nal.usda.gov/api-key-signup.html
USDA_FDC_API_KEY=""

